includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 6
    paths:
        - app
    excludePaths:
        - 'app/Modules/*/Tests/*'
    ignoreErrors:
        - identifier: missingType.generics

services:
    -
        class: App\Rules\PHPStan\NoCrossModuleModelImportRule
        tags:
            - phpstan.rules.rule
