APP_NAME="E-commerce Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stderr
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ecommerce
DB_USERNAME=ecommerce
DB_PASSWORD=secret

CACHE_STORE=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SCHEME=tcp
REDIS_PASSWORD=redispassword
REDIS_CACHE_DB=0
REDIS_SESSION_DB=1

FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# PHP-FPM — workers spawned on demand; override per environment
PHP_FPM_MAX_CHILDREN=10
